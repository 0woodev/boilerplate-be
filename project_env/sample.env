# ============================================================
# Repository variables (stage 무관 공통값)
# GitHub: Settings → Variables → Repository variables
# ============================================================
PROJECT_NAME="my-project"
GITHUB_OWNER="my-github-org"
AWS_REGION="ap-northeast-2"
AWS_ACCOUNT_ID=""

# TF_STATE_BUCKET: aws_setup.sh 으로 생성된 버킷명과 동일해야 함
TF_STATE_BUCKET="${GITHUB_OWNER}-${PROJECT_NAME}-tf-state"

# ============================================================
# Environment variables (stage별 다른 값)
# GitHub: Settings → Variables → Environments → dev / prod
# ============================================================

# FE_DOMAIN: CORS 허용 origin. 전체 URL 형식 (https:// 포함)
# dev  예시: https://dev.my-project.com 또는 http://localhost:3000
# prod 예시: https://my-project.com
FE_DOMAIN="http://localhost:3000"
