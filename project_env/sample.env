# ============================================================
# Project
# ============================================================
PROJECT_NAME="my-project"

# ============================================================
# GitHub
# ============================================================
GITHUB_OWNER="my-github-org"

# ============================================================
# AWS
# ============================================================
AWS_REGION="ap-northeast-2"
AWS_ACCOUNT_ID=""

# ============================================================
# Terraform State
# TF_STATE_BUCKET: S3 버킷명 (aws_setup.sh 으로 생성된 버킷명과 동일해야 함)
# ============================================================
TF_STATE_BUCKET="${GITHUB_OWNER}-${PROJECT_NAME}-tf-state"

# ============================================================
# Frontend Domain (CORS)
# 전체 URL 형식으로 입력. ex) https://my-app.com
# 로컬 개발 시: http://localhost:3000
# ============================================================
FE_DOMAIN="http://localhost:3000"
